{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tschneider-imagine/VEGM/schemas/message-pack.schema.json",
  "title": "VEGM Message Pack v1",
  "type": "object",
  "required": [
    "schema_version",
    "pack_name",
    "pack_version",
    "wire",
    "control_plane",
    "timers",
    "state_defaults",
    "operations"
  ],
  "properties": {
    "schema_version": {"const": "vegm.message-pack/v1"},
    "pack_name": {"type": "string", "minLength": 1},
    "pack_version": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "extends": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "wire": {
      "type": "object",
      "required": ["protocol_family", "transport", "envelope", "paths", "namespaces"],
      "properties": {
        "protocol_family": {"const": "g2s"},
        "transport": {
          "type": "object",
          "required": ["http_versions", "tls_modes_supported", "content_types"],
          "properties": {
            "http_versions": {"type": "array", "items": {"type": "string"}},
            "tls_modes_supported": {
              "type": "array",
              "items": {
                "enum": ["plaintext_lab", "tls_server_only", "strict_mtls", "mtls_no_revocation", "accept_all_lab"]
              }
            },
            "content_types": {"type": "array", "items": {"type": "string"}},
            "soap_action_required": {"type": "boolean"}
          },
          "additionalProperties": true
        },
        "envelope": {
          "type": "object",
          "required": ["kind"],
          "properties": {
            "kind": {"const": "soap-http"},
            "soap_namespace": {"type": "string"},
            "body_xpath_hint": {"type": "string"},
            "header_xpath_hint": {"type": "string"}
          },
          "additionalProperties": true
        },
        "paths": {
          "type": "object",
          "required": ["default_listener_path"],
          "properties": {
            "default_listener_path": {"type": "string", "minLength": 1},
            "alternate_listener_paths": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": true
        },
        "namespaces": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "control_plane": {
      "type": "object",
      "required": ["hot_reloadable_sections", "mutable_fields"],
      "properties": {
        "hot_reloadable_sections": {"type": "array", "items": {"type": "string"}},
        "mutable_fields": {"type": "array", "items": {"type": "string"}},
        "requires_audit_log": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "timers": {
      "type": "object",
      "required": ["request_timeout_ms", "heartbeat_interval_ms", "heartbeat_timeout_ms"],
      "properties": {
        "request_timeout_ms": {"type": "integer", "minimum": 0},
        "heartbeat_interval_ms": {"type": "integer", "minimum": 0},
        "heartbeat_timeout_ms": {"type": "integer", "minimum": 0},
        "session_idle_timeout_ms": {"type": "integer", "minimum": 0},
        "artificial_response_delay_ms": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": true
    },
    "state_defaults": {
      "type": "object",
      "required": ["registration_mode", "session_state", "heartbeat_state"],
      "properties": {
        "registration_mode": {"enum": ["open", "strict_match", "deny_all", "simulate_vendor_quirk"]},
        "session_state": {"enum": ["idle", "online", "closed", "degraded"]},
        "heartbeat_state": {"enum": ["idle", "healthy", "degraded", "timeout"]},
        "allowed_host_ids": {"type": "array", "items": {"type": "string"}},
        "registered_hosts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["host_id", "enabled"],
            "properties": {
              "host_id": {"type": "string"},
              "display_name": {"type": "string"},
              "role": {"type": "string"},
              "enabled": {"type": "boolean"},
              "notes": {"type": "string"}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "logging_hints": {"type": "object"},
    "operations": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["enabled", "direction", "match", "extract", "responses"],
        "properties": {
          "enabled": {"type": "boolean"},
          "description": {"type": "string"},
          "direction": {"enum": ["inbound", "outbound", "bidirectional"]},
          "match": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind", "value"],
              "properties": {
                "kind": {"enum": ["message_type", "path", "namespace", "field_equals", "always"]},
                "value": {"type": "string"},
                "source": {"type": "string"}
              },
              "additionalProperties": true
            }
          },
          "extract": {"type": "array"},
          "responses": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["variant_name", "template"],
              "properties": {
                "variant_name": {"type": "string"},
                "template": {"type": "string"},
                "set_state": {"type": "object"},
                "http_status": {"type": "integer"},
                "headers": {"type": "object", "additionalProperties": {"type": "string"}},
                "delay_ms": {"type": "integer", "minimum": 0}
              },
              "additionalProperties": true
            }
          },
          "fault_policy": {"type": "object"},
          "log_fields": {"type": "array", "items": {"type": "string"}}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
