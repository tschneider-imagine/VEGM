<xs:schema xmlns:ccSmd="http://g2s.igt.com/commConfig/smdExt/v1.0.0" xmlns:xs="http://www.w3.org/2001/XMLSchema" xmlns:g2s="http://www.gamingstandards.com/g2s/schemas/v1.0.3" targetNamespace="http://g2s.igt.com/commConfig/smdExt/v1.0.0" elementFormDefault="qualified" attributeFormDefault="qualified">
	<xs:import namespace="http://www.gamingstandards.com/g2s/schemas/v1.0.3" schemaLocation="g2sIncludeGlobal.xsd"/>
	<!--Simple Data Types-->
	<xs:simpleType name="t_deviceStateTag">
		<xs:annotation>
			<xs:documentation>Device State Tag Data Type</xs:documentation>
		</xs:annotation>
		<xs:restriction base="g2s:t_uniqueIdentifier64"/>
	</xs:simpleType>
	<!--Attribute Groups-->
	<xs:attributeGroup name="p_deviceStateTags">
		<xs:annotation>
			<xs:documentation>Device State Tag Attribute Group</xs:documentation>
		</xs:annotation>
		<xs:attribute name="stateTag" type="ccSmd:t_deviceStateTag" use="optional" default="IGT_none"/>
	</xs:attributeGroup>
</xs:schema>
