{
  "schema_version": "vegm.fleet-manifest/v1",
  "fleet_name": "lab-floor-a",
  "description": "Example mixed-floor manifest for supervisor-driven VEGM generation and launch.",
  "defaults": {
    "host_id": "HOST-001",
    "listen_host": "192.168.10.162",
    "wire_port_base": 18443,
    "control_port_base": 19001,
    "egm_endpoint": {
      "scheme": "http",
      "bind_ip": "192.168.10.162",
      "host": "192.168.10.162",
      "path": "/g2s"
    },
    "host_endpoint": {
      "url": "http://tspi4.local:8444/g2s"
    },
    "trust_mode": "plaintext_lab",
    "pack_file": "./example.pack.json",
    "overlay_files": [],
    "log_root": "./logs/fleet-a",
    "storage_backend": "sqlite",
    "sqlite_root": "./logs/fleet-a",
    "advertised_host": "192.168.10.162",
    "advertised_ip": "192.168.10.162",
    "dns_servers": ["8.8.8.8", "1.1.1.1"],
    "subnet_mask": "255.255.255.0",
    "gateway": "192.168.10.1",
    "heartbeat": {
      "enabled": true,
      "interval_ms": 5000,
      "timeout_ms": 12000,
      "jitter_ms": 0,
      "auto_start": false
    },
    "normalized_state": {
      "audio_state": "normal",
      "hold_state": "inactive",
      "lock_state": "inactive",
      "machine_state": "available"
    }
  },
  "profiles": {
    "baseline": {
      "label": "Baseline simulated floor profile",
      "manufacturer": "generic",
      "pack_file": "./example.pack.json",
      "overlay_files": [],
      "logical_commands": {
        "audio_mute_on": "audioMuteOn",
        "audio_mute_off": "audioMuteOff",
        "hold_on": "holdOn",
        "hold_off": "holdOff",
        "lock_on": "lockOn",
        "lock_off": "lockOff"
      },
      "advertised_host": "192.168.10.162"
    },
    "vendorquirk": {
      "label": "Vendor quirk profile",
      "manufacturer": "mixed-vendor",
      "pack_file": "./example.vendorquirk.pack.json",
      "overlay_files": [],
      "logical_commands": {
        "audio_mute_on": "audioMuteOn",
        "audio_mute_off": "audioMuteOff",
        "hold_on": "holdOn",
        "hold_off": "holdOff",
        "lock_on": "lockOn",
        "lock_off": "lockOff"
      },
      "advertised_host": "192.168.10.162",
      "server_name": "192.168.10.162",
      "cert_file": "./certs/vendor/server.pem",
      "key_file": "./certs/vendor/server.key",
      "ca_file": "./certs/vendor/ca.pem",
      "heartbeat": {
        "interval_ms": 8000,
        "auto_start": false
      }
    }
  },
  "groups": {
    "bank_a": {
      "label": "Bank A",
      "profile": "baseline",
      "zone": "A"
    },
    "bank_b": {
      "label": "Bank B",
      "profile": "vendorquirk",
      "zone": "B",
      "overrides": {
        "heartbeat": {
          "interval_ms": 7000
        }
      }
    }
  },
  "instances": [
    {
      "instance_id": "vegm-001",
      "egm_id": "EGM-001",
      "host_id": "HOST-001",
      "group": "bank_a",
      "wire_port": 18443,
      "control_port": 19001,
      "egm_endpoint": {
        "host": "192.168.10.162",
        "port": 18443,
        "path": "/g2s"
      },
      "host_endpoint": {
        "url": "http://tspi4.local:8444/g2s"
      },
      "advertised_host": "192.168.10.162",
      "advertised_ip": "192.168.10.162"
    },
    {
      "instance_id": "vegm-002",
      "egm_id": "EGM-002",
      "host_id": "HOST-001",
      "group": "bank_a",
      "wire_port": 18444,
      "control_port": 19002,
      "egm_endpoint": {
        "host": "192.168.10.162",
        "port": 18444,
        "path": "/g2s"
      },
      "host_endpoint": {
        "url": "http://tspi4.local:8444/g2s"
      },
      "advertised_host": "192.168.10.162",
      "advertised_ip": "192.168.10.162"
    },
    {
      "instance_id": "vegm-011",
      "egm_id": "EGM-011",
      "host_id": "HOST-001",
      "group": "bank_b",
      "wire_port": 18453,
      "control_port": 19011,
      "egm_endpoint": {
        "host": "192.168.10.162",
        "port": 18453,
        "path": "/g2s"
      },
      "host_endpoint": {
        "url": "http://tspi4.local:8444/g2s"
      },
      "advertised_host": "192.168.10.162",
      "advertised_ip": "192.168.10.162",
      "subnet_mask": "255.255.255.0",
      "gateway": "192.168.10.1",
      "overrides": {
        "normalized_state": {
          "audio_state": "normal",
          "hold_state": "inactive",
          "lock_state": "inactive",
          "machine_state": "available"
        }
      }
    }
  ]
}
